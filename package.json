{
  "name": "pdftools-app",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "start:dev": "bash scripts/dev.sh",
    "stop:dev": "bash scripts/stop.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:engine": "npm run build -w pdfflow-engine",
    "postinstall": "mkdir -p public/pdfjs/standard_fonts && cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs public/pdfjs/pdf.worker.min.mjs && cp -r node_modules/pdfjs-dist/standard_fonts/. public/pdfjs/standard_fonts/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "worker": "tsx src/worker/index.ts",
    "docker:up": "docker compose --env-file .env.docker up -d --build",
    "docker:down": "docker compose --env-file .env.docker down",
    "docker:logs": "docker compose --env-file .env.docker logs -f"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@napi-rs/canvas": "^1.0.2",
    "@pdf-lib/fontkit": "^1.1.1",
    "@pdfsmaller/pdf-encrypt": "^1.0.2",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.16",
    "@radix-ui/react-toast": "^1.2.18",
    "bcryptjs": "^3.0.3",
    "browser-image-compression": "^2.0.2",
    "bullmq": "^5.79.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "ioredis": "^5.11.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.23.0",
    "mammoth": "^1.12.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.13.1",
    "pdf-lib": "^1.17.1",
    "pdfium-native": "^0.6.0",
    "pdfjs-dist": "^6.1.200",
    "postgres": "^3.4.9",
    "pptxgenjs": "^4.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.6.0",
    "tesseract.js": "^7.0.0",
    "uuid": "^14.0.1",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
